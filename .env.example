# Application Configuration
APP_NAME="Nova Cloud Hosting"
APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=http://localhost
APP_TIMEZONE=Africa/Kampala
APP_LOCALE=en

# Database Configuration
DB_CONNECTION=sqlite
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=monitor.db
DB_USERNAME=root
DB_PASSWORD=

# SMTP Configuration
MAIL_DRIVER=smtp
MAIL_HOST=mail-gw.ncedges.com
MAIL_PORT=465
MAIL_USERNAME=webadmin@ncedges.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=webadmin@ncedges.com
MAIL_FROM_NAME="Monitor System"
MAIL_REPLY_TO_ADDRESS=support@ncedges.com
MAIL_TIMEOUT=10

# Alert Configuration
ALERT_EMAIL=webadmin@ncedges.com
ALERT_EMAIL_CC=
ALERT_EMAIL_BCC=
NOTIFY_ADMIN_EMAIL=

# Monitoring Configuration
MONITOR_REFRESH_INTERVAL=30
HEALTH_CHECK_TIMEOUT=3
ALERT_AFTER_SECONDS=300
CRITICAL_AFTER_SECONDS=900

# Notification Configuration
NOTIFICATIONS_ENABLED=true
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_SMS_ENABLED=false
NOTIFICATION_PUSH_ENABLED=false
NOTIFICATION_IN_APP_ENABLED=true
NOTIFICATION_THROTTLE_ENABLED=true
NOTIFICATION_THROTTLE_MINUTES=30

# Logging Configuration
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_RETENTION_DAYS=30

# Theme Configuration
APP_THEME=dark
USER_CAN_CHANGE_THEME=true

# Security Configuration
AUTH_SESSION_TIMEOUT=3600
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

# Session Configuration
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_COOKIE=monitor_session
SESSION_SECURE=false
SESSION_HTTP_ONLY=true

# Cache Configuration
CACHE_DRIVER=file
CACHE_TTL=3600

# Feature Flags
AUDIT_LOGGING_ENABLED=true
ACTIVITY_TIMELINE_ENABLED=true
AUTO_REFRESH_ENABLED=true
